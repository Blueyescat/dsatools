{
  "name": "dsatools",
  "version": "1.0.0",
  "description": "A website and PWA for various tools for the Deep Space Airships game (drednot.io).",
  "homepage": "https://github.com/Blueyescat/dsatools",
  "bugs": "https://github.com/Blueyescat/dsatools/issues",
  "author": "Blueyescat <blueyescat123@gmail.com>",
  "license": "GPL-3.0-only",
  "type": "module",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p server --noEmit && tsc -p client --noEmit",
    "build": "npm run build --workspaces",
    "start": "npm run start -w server",
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\""
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.77",
    "concurrently": "^9.2.3",
    "dsabp-js": "^0.4.13",
    "dsabp-js-img": "^0.1.0",
    "ejs": "^3.1.10",
    "isomorphic-dompurify": "^2.26.0",
    "marked": "^15.0.11"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  }
}
